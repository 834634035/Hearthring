{
  "name": "@tribal-epic/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npx tsx watch --env-file=.env src/server.ts",
    "start": "npx tsx --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "db:seed": "npx tsx --env-file=.env src/seed.ts",
    "db:migrate": "npx tsx --env-file=.env src/migrate-cli.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts apps/api"
  },
  "dependencies": {
    "@tribal-epic/shared": "*",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mysql2": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
